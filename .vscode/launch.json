{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Split CIS Policies (Dry Run)",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/split_cis_policies.py",
      "args": [
        "--path", "${workspaceFolder}/IntuneWindows11v4.0.0/Settings Catalog",
        "--config", "${workspaceFolder}/cis-control-config.json",
        "--dry-run"
      ],
      "console": "integratedTerminal"
    },
    {
      "name": "Split CIS Policies",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/split_cis_policies.py",
      "args": [
        "--path", "${workspaceFolder}/IntuneWindows11v4.0.0/Settings Catalog",
        "--config", "${workspaceFolder}/cis-control-config.json",
        "--output", "${workspaceFolder}/output"
      ],
      "console": "integratedTerminal"
    },
    {
      "name": "Deploy QA: 1 Baseline Only",
      "type": "PowerShell",
      "request": "launch",
      "script": "${workspaceFolder}/Deploy-CISPolicies.ps1",
      "args": [
        "-Tenant", "QA",
        "-PolicyFile",
        "'${workspaceFolder}/output/baseline/CIS L1 - Auditing.json'",
        "-WhatIf"
      ]
    },
    {
      "name": "Deploy QA: Baseline + Exceptionable",
      "type": "PowerShell",
      "request": "launch",
      "script": "${workspaceFolder}/Deploy-CISPolicies.ps1",
      "args": [
        "-Tenant", "QA",
        "-PolicyFile",
        "'${workspaceFolder}/output/baseline/CIS L1 - Auditing.json','${workspaceFolder}/output/exceptionable/CIS 4.10.9.2 - Prevent Device Metadata Retrieval from Network - Baseline.json'",
        "-WhatIf"
      ]
    },
    {
      "name": "Deploy QA: Baseline + Exceptionable + Alt",
      "type": "PowerShell",
      "request": "launch",
      "script": "${workspaceFolder}/Deploy-CISPolicies.ps1",
      "args": [
        "-Tenant", "QA",
        "-PolicyFile",
        "'${workspaceFolder}/output/baseline/CIS L1 - Auditing.json','${workspaceFolder}/output/exceptionable/CIS 4.10.9.2 - Prevent Device Metadata Retrieval from Network - Baseline.json','${workspaceFolder}/output/exceptionable/CIS 4.10.9.2 - Prevent Device Metadata Retrieval from Network - Alt (allowed).json'",
        "-WhatIf"
      ]
    },
    {
      "name": "Deploy LIVE Prod: Baseline + Exceptionable + Alt",
      "type": "PowerShell",
      "request": "launch",
      "script": "${workspaceFolder}/Deploy-CISPolicies.ps1",
      "args": [
        "-Tenant", "Prod",
        "-PolicyFile",
        "'${workspaceFolder}/output/baseline/CIS L1 - Auditing.json','${workspaceFolder}/output/exceptionable/CIS 4.10.9.2 - Prevent Device Metadata Retrieval from Network - Baseline.json','${workspaceFolder}/output/exceptionable/CIS 4.10.9.2 - Prevent Device Metadata Retrieval from Network - Alt (allowed).json'"
      ]
    },
    {
      "name": "Deploy LIVE Prod: All Policies (Manifest)",
      "type": "PowerShell",
      "request": "launch",
      "script": "${workspaceFolder}/Deploy-CISPolicies.ps1",
      "args": [
        "-Tenant", "Prod",
        "-ManifestFile", "${workspaceFolder}/output/manifest.json"
      ]
    },
    {
      "name": "Deploy PROD: BitLocker Only",
      "type": "PowerShell",
      "request": "launch",
      "script": "${workspaceFolder}/Deploy-CISPolicies.ps1",
      "args": [
        "-Tenant", "Prod",
        "-PolicyFile",
        "'${workspaceFolder}/output/baseline/CIS BL - BitLocker.json'"
      ]
    },
    {
      "name": "Export CIS Policies (Prod)",
      "type": "PowerShell",
      "request": "launch",
      "script": "${workspaceFolder}/Export-CISPolicies.ps1",
      "args": [
        "-Tenant", "Prod"
      ]
    },
    {
      "name": "Delete PROD",
      "type": "PowerShell",
      "request": "launch",
      "script": "${workspaceFolder}/Delete-CISPolicies.ps1",
      "args": [
        "-Tenant", "Prod",
        "-CsvFile", "${workspaceFolder}/cis-policies-prod.csv",
      ]
    },
    {
      "name": "Get Group Assignments (Prod)",
      "type": "PowerShell",
      "request": "launch",
      "script": "${workspaceFolder}/Get-GroupPolicyAssignments.ps1",
      "args": [
        "-Tenant", "Prod",
        "-GroupName", "9047i-dw-win-autopilot-devices"
      ]
    },
    {
      "name": "Split CIS Services",
      "type": "debugpy",
      "request": "launch",
      "program": "${workspaceFolder}/split_cis_services.py",
      "args": [
        "--source", "${workspaceFolder}/IntuneWindows11v4.0.0/System Service Scripts",
        "--config", "${workspaceFolder}/cis-control-config.json",
        "--output", "${workspaceFolder}/output"
      ],
      "console": "integratedTerminal"
    },
    {
      "name": "Deploy Services: TestMode",
      "type": "PowerShell",
      "request": "launch",
      "script": "${workspaceFolder}/Deploy-CISServices.ps1",
      "args": [
        "-Tenant", "Prod",
        "-ManifestFile", "${workspaceFolder}/output/manifest.json",
        "-TestMode"
      ]
    }
  ]
}
