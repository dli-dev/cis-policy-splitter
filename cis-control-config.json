    "4.11.7.2.9": {
      "disposition": "modified",
      "description": "Require Additional Authentication at Startup (BitLocker)",
      "settingDefinitionId": "device_vendor_msft_bitlocker_systemdrivesrequirestartupauthentication",
      "isChild": false,
      "cisValue": "Enabled — but with PIN required (4.11.7.2.12) and TPM-only forbidden (4.11.7.2.13)",
      "ourValue": "Enabled — TPM-only required, PIN/key/PIN+key all forbidden",
      "modifiedValue": "device_vendor_msft_bitlocker_systemdrivesrequirestartupauthentication_1",
      "_note": "Changed from reject — parent enables the policy. CIS pairs this with require-PIN (breaks Autopilot); we deviate by requiring TPM-only instead. Sibling children TPM+key, TPM+PIN+key, and non-TPM accept upstream CIS _0 (Do not allow) by default and are not separately tracked."
    },
    "4.11.7.2.12": {
      "disposition": "modified",
      "description": "Configure TPM Startup PIN (BitLocker)",
      "settingDefinitionId": "device_vendor_msft_bitlocker_systemdrivesrequirestartupauthentication_configurepinusagedropdown_name",
      "isChild": true,
      "cisValue": "Require startup PIN with TPM (_1)",
      "ourValue": "Do not allow startup PIN with TPM (_0)",
      "modifiedValue": "device_vendor_msft_bitlocker_systemdrivesrequirestartupauthentication_configurepinusagedropdown_name_0",
      "_note": "CIS forces PIN at every boot, which breaks Autopilot/silent BitLocker. We disallow PIN entirely; TPM-only is the only mode."
    },
    "4.11.7.2.13": {
      "disposition": "modified",
      "description": "Configure TPM Startup (BitLocker)",
      "settingDefinitionId": "device_vendor_msft_bitlocker_systemdrivesrequirestartupauthentication_configuretpmusagedropdown_name",
      "isChild": true,
      "cisValue": "Do not allow TPM (_0)",
      "ourValue": "Require TPM (_1)",
      "modifiedValue": "device_vendor_msft_bitlocker_systemdrivesrequirestartupauthentication_configuretpmusagedropdown_name_1",
      "_note": "CIS forbids TPM-only (because it pairs with PIN-required). We require TPM-only, so this flips from forbid to require."
    },

